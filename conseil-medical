        'sy': { risque: 'élevé', alerte: '⚠️ Accès aux soins très limité.' },
        'iq': { risque: 'élevé', alerte: '⚠️ Risque choléra et accès aux soins limité.' },
        'ly': { risque: 'modéré', alerte: '⚠️ Risque épidémique.' },
        'lb': { risque: 'modéré', alerte: '⚠️ Risque épidémique (pays hôte de réfugiés).' },
    };

    const conseilsSymptomes = {
        'fievre': '📌 La fièvre peut indiquer une infection. Consultez si persistance > 48h.',
        'toux': '📌 Repos, hydratation. Consultez si essoufflement.',
        'maux_de_tete': '📌 Repos, hydratation. Consultez si intenses.',
        'douleur_thoracique': '⚠️ URGENCE – Consultez immédiatement.',
        'essoufflement': '⚠️ URGENCE – Appelez le 15/911.',
        'nausees': '📌 Alimentation légère. Consultez si vomissements.',
        'diarrhee': '📌 Hydratation essentielle. Consultez si sévère.',
        'douleur_articulaire': '📌 Repos, antalgiques. Consultez si fièvre.',
        'fatigue': '📌 Repos. Consultez si persistante.',
        'douleur_abdominale': '📌 Surveillez l\'évolution. Consultez si intense.',
    };

    const paysVectoriels = ['pk','so','ke','mu','fr','it','in','bd','lk','th','mx','br','ar','co','pe','id','my','ph','ve','ht'];
    const paysCholera = ['cd','sd','ss','td','cg','ng','gh','et','tz','zm','zw','ht','ye','iq','sy'];
    const paysPaludisme = ['ye','af','dj','vn','kh','la','mm','cn','et','tz','zm','zw','cd','cg','td','ke','so','sd','ss'];

    const nomsPays = {
        'fr':'France','de':'Allemagne','es':'Espagne','it':'Italie','pt':'Portugal',
        'nl':'Pays-Bas','be':'Belgique','ch':'Suisse','at':'Autriche','se':'Suède',
        'no':'Norvège','dk':'Danemark','fi':'Finlande','ie':'Irlande','uk':'Royaume-Uni',
        'pl':'Pologne','ua':'Ukraine','ru':'Russie','ca':'Canada','us':'États-Unis',
        'mx':'Mexique','br':'Brésil','ar':'Argentine','co':'Colombie','pe':'Pérou',
        've':'Venezuela','ht':'Haïti','za':'Afrique du Sud','ng':'Nigeria','ke':'Kenya',
        'gh':'Ghana','ma':'Maroc','tn':'Tunisie','dz':'Algérie','eg':'Égypte',
        'cd':'RDC','sd':'Soudan','ss':'Soudan du Sud','td':'Tchad','cg':'République du Congo',
        'et':'Éthiopie','tz':'Tanzanie','zm':'Zambie','zw':'Zimbabwe','au':'Australie',
        'nz':'Nouvelle-Zélande','in':'Inde','pk':'Pakistan','bd':'Bangladesh','lk':'Sri Lanka',
        'th':'Thaïlande','vn':'Viêt Nam','kh':'Cambodge','la':'Laos','mm':'Myanmar',
        'cn':'Chine','jp':'Japon','kr':'Corée du Sud','id':'Indonésie','my':'Malaisie',
        'ph':'Philippines','ye':'Yémen','af':'Afghanistan','ir':'Iran','sa':'Arabie Saoudite',
        'ae':'Émirats Arabes Unis','sy':'Syrie','iq':'Irak','ly':'Libye','lb':'Liban'
    };

    // ============================================================
    // 3. LOGIQUE PRINCIPALE
    // ============================================================
    let dernierConseil = '';

    document.getElementById('obtenirConseil').addEventListener('click', function() {
        const codePays = document.getElementById('pays').value;
        const paysNom = nomsPays[codePays] || 'Pays non reconnu';
        const age = document.getElementById('age').value || 'Non renseigné';
        const sexe = document.getElementById('sexe').value || 'Non précisé';
        const symptome = document.getElementById('symptomes').value;
        const symptomeNom = document.getElementById('symptomes').options[document.getElementById('symptomes').selectedIndex]?.text || 'Non précisé';
        const description = document.getElementById('description').value || 'Aucune description';

        if (!codePays) { alert('Veuillez sélectionner un pays.'); return; }

        const dataEpi = epidemiologie[codePays] || { risque: 'faible', alerte: '✅ Situation épidémiologique stable.' };

        let conseil = '';
        conseil += '🏥 HEALTH AI – CONSEIL MÉDICAL\n';
        conseil += '═'.repeat(44) + '\n';
        conseil += '📌 Pays : ' + paysNom + '\n';
        conseil += '📅 Âge : ' + age + ' ans\n';
        conseil += '⚧️ Sexe : ' + sexe + '\n';
        conseil += '🩺 Symptôme : ' + symptomeNom + '\n';
        conseil += '📝 Description : ' + description + '\n';
        conseil += '═'.repeat(44) + '\n\n';

        conseil += '📊 SITUATION ÉPIDÉMIOLOGIQUE (' + paysNom + ')\n';
        conseil += dataEpi.alerte + '\n\n';

        if (symptome && conseilsSymptomes[symptome]) {
            conseil += '💡 CONSEIL SPÉCIFIQUE\n';
            conseil += conseilsSymptomes[symptome] + '\n\n';
        }

        conseil += '📋 RECOMMANDATIONS GÉNÉRALES\n';
        if (dataEpi.risque === 'élevé') {
            conseil += '🔴 RISQUE ÉLEVÉ – Vigilance maximale.\n';
            conseil += '   • Consultez un médecin sans délai.\n';
            conseil += '   • En cas de diarrhée aqueuse, hydratez-vous.\n';
        } else if (dataEpi.risque === 'modéré') {
            conseil += '🟡 RISQUE MODÉRÉ – Restez attentif.\n';
            conseil += '   • Consultez si les symptômes persistent > 48h.\n';
        } else {
            conseil += '🟢 RISQUE FAIBLE – Situation stable.\n';
            conseil += '   • Suivez les recommandations habituelles.\n';
        }

        if (paysVectoriels.includes(codePays)) {
            conseil += '\n🦟 ALERTE VECTORIELLE :\n   • Protégez-vous des moustiques.\n';
        }
        if (paysCholera.includes(codePays)) {
            conseil += '\n💧 ALERTE CHOLÉRA :\n   • Buvez de l\'eau potable.\n   • Lavez-vous les mains.\n';
        }
        if (paysPaludisme.includes(codePays)) {
            conseil += '\n🦟 ALERTE PALUDISME :\n   • Protection anti-moustique.\n   • Consultez en cas de fièvre.\n';
        }

        conseil += '\n' + '═'.repeat(44) + '\n';
        conseil += '⚠️ Ce conseil ne remplace pas une consultation médicale.\n';
        conseil += '📞 Urgence : 15 (France) / 911 (Canada/US)';

        dernierConseil = conseil;

        const resultatDiv = document.getElementById('conseilResultat');
        resultatDiv.textContent = conseil;
        resultatDiv.style.display = 'block';
        resultatDiv.className = '';
        if (dataEpi.risque === 'élevé') resultatDiv.classList.add('urgence');
        else if (dataEpi.risque === 'modéré') resultatDiv.classList.add('alerte');
        resultatDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });

    // ============================================================
    // 4. EXPORT PDF
    // ============================================================
    document.getElementById('exportPDF').addEventListener('click', function() {
        if (!dernierConseil) {
            alert('Veuillez d\'abord obtenir un conseil médical.');
            return;
        }

        const { jsPDF } = window.jspdf;
        const doc = new jsPDF('p', 'mm', 'a4');
        const lines = doc.splitTextToSize(dernierConseil, 180);
        doc.setFontSize(10);
        doc.text(lines, 15, 20);
        doc.save('conseil_medical_health_ai.pdf');
    });

    // ============================================================
    // 5. CARTE INTERACTIVE (Leaflet)
    // ============================================================
    let mapInitialized = false;
    let map = null;

    document.getElementById('toggleCarte').addEventListener('click', function() {
        const container = document.getElementById('carteContainer');
        container.classList.toggle('active');
        
        if (container.classList.contains('active') && !mapInitialized) {
            map = L.map('carteContainer').setView([20, 0], 2);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© OpenStreetMap'
            }).addTo(map);

            // Marqueurs pour les pays à risque
            const paysRisque = {
                'cd': { lat: -4.038, lng: 21.759, label: 'RDC - Choléra' },
                'sd': { lat: 15.500, lng: 32.560, label: 'Soudan - Choléra' },
                'ss': { lat: 7.862, lng: 29.694, label: 'Soudan du Sud - Choléra' },
                'td': { lat: 15.454, lng: 18.732, label: 'Tchad - Choléra' },
                'cg': { lat: -4.263, lng: 15.243, label: 'Congo - Choléra' },
                'pk': { lat: 30.375, lng: 69.345, label: 'Pakistan - Chikungunya' },
                'ke': { lat: -1.286, lng: 36.817, label: 'Kenya - Chikungunya' },
                'br': { lat: -14.235, lng: -51.925, label: 'Brésil - Chikungunya' },
                'ht': { lat: 18.971, lng: -72.285, label: 'Haïti - Choléra' },
                'ye': { lat: 15.553, lng: 48.516, label: 'Yémen - Paludisme' },
                'af': { lat: 33.939, lng: 67.710, label: 'Afghanistan - Paludisme' },
                'et': { lat: 9.145, lng: 40.490, label: 'Éthiopie - Choléra' },
                'tz': { lat: -6.369, lng: 34.889, label: 'Tanzanie - Choléra' },
                'zm': { lat: -13.134, lng: 27.849, label: 'Zambie - Choléra' },
                'zw': { lat: -19.015, lng: 29.155, label: 'Zimbabwe - Choléra' },
                'so': { lat: 5.152, lng: 46.200, label: 'Somalie - Chikungunya' },
                'mu': { lat: -20.348, lng: 57.552, label: 'Maurice - Chikungunya' },
                'in': { lat: 20.594, lng: 78.963, label: 'Inde - Chikungunya' },
                'bd': { lat: 23.685, lng: 90.356, label: 'Bangladesh - Chikungunya' },
                'lk': { lat: 7.873, lng: 80.772, label: 'Sri Lanka - Chikungunya' },
                'th': { lat: 15.870, lng: 100.993, label: 'Thaïlande - Chikungunya' },
                'id': { lat: -0.789, lng: 113.921, label: 'Indonésie - Risque vectoriel' },
                'ph': { lat: 12.880, lng: 121.774, label: 'Philippines - Risque vectoriel' },
                'vn': { lat: 14.058, lng: 108.277, label: 'Viêt Nam - Paludisme' },
                'kh': { lat: 12.565, lng: 104.991, label: 'Cambodge - Paludisme' },
                'la': { lat: 19.856, lng: 102.495, label: 'Laos - Paludisme' },
                'mm': { lat: 21.914, lng: 95.956, label: 'Myanmar - Paludisme' },
                'sy': { lat: 34.802, lng: 38.997, label: 'Syrie - Crise humanitaire' },
                'iq': { lat: 33.223, lng: 43.679, label: 'Irak - Crise humanitaire' },
            };

            // Couleurs par risque
            const couleurs = {
                'élevé': 'red',
                'modéré': 'orange',
                'faible': 'green'
            };

            for (const [code, data] of Object.entries(paysRisque)) {
                const epi = epidemiologie[code] || { risque: 'faible' };
                const couleur = couleurs[epi.risque] || 'blue';
                L.circleMarker([data.lat, data.lng], {
                    radius: 10,
                    color: couleur,
                    fillColor: couleur,
                    fillOpacity: 0.6,
                    weight: 2
                }).addTo(map)
                .bindPopup(`<b>${data.label}</b><br>Risque: ${epi.risque || 'inconnu'}`);
            }

            mapInitialized = true;
        } else if (container.classList.contains('active') && mapInitialized) {
            setTimeout(() => map.invalidateSize(), 300);
        }
    });

    // ============================================================
    // 6. INITIALISATION
    // ============================================================
    switchLang('fr');
</script>

</body>
</html>
