        #conseilResultat.alerte { border-left-color: #f57c00; background: #fff8e1; }
        
        /* ===== CARTE ===== */
        #carteContainer {
            display: none; margin-top: 18px; height: 350px;
            border-radius: 10px; overflow: hidden; border: 1px solid #ddd;
        }
        #carteContainer.active { display: block; }
        
        /* ===== AVERTISSEMENT ===== */
        .warning {
            font-size: 11px; color: #777; margin-top: 14px; text-align: center;
            border-top: 1px solid #e9ecef; padding-top: 14px;
        }
        .warning strong { color: #c62828; }
        @media (max-width: 500px) {
            .container { padding: 16px; }
            h1 { font-size: 20px; }
            .btn { font-size: 13px; padding: 10px; min-width: 80px; }
            .header { flex-direction: column; align-items: stretch; }
