        h1 small { display: block; font-size: 12px; color: #555; font-weight: normal; }
        .badge-anonyme {
            background: #e8f5e9; color: #1b5e20; font-size: 11px; font-weight: bold;
            padding: 3px 14px; border-radius: 20px; display: inline-block;
        }
        .lang-switch {
            display: flex; gap: 6px; align-items: center;
        }
        .lang-btn {
            background: #e8f5e9; border: 1.5px solid #a5d6a7; padding: 4px 12px;
            border-radius: 20px; cursor: pointer; font-size: 13px; font-weight: 600;
            transition: 0.2s; color: #1b5e20;
        }
        .lang-btn.active { background: #1b5e20; color: white; border-color: #1b5e20; }
        .lang-btn:hover { background: #2e7d32; color: white; }
        .subtitle { text-align: center; color: #666; font-size: 13px; margin: 4px 0 14px; }
        
        /* ===== FORMULAIRES ===== */
        label { display: block; margin-top: 14px; font-weight: 600; color: #1b5e20; font-size: 13px; }
        select, input, textarea {
            width: 100%; padding: 9px 12px; margin-top: 3px;
            border: 1.5px solid #d0d7de; border-radius: 8px; font-size: 13px;
            background: #fafbfc; font-family: inherit;
        }
        select:focus, input:focus, textarea:focus {
            border-color: #2e7d32; box-shadow: 0 0 0 3px rgba(46,125,50,0.12);
            outline: none; background: #fff;
        }
        textarea { height: 60px; resize: vertical; }
        .pays-info { font-size: 11px; color: #888; text-align: right; margin-top: 2px; }
        
        /* ===== BOUTONS ===== */
        .btn-group { display: flex; gap: 10px; margin-top: 18px; flex-wrap: wrap; }
        .btn {
            background: #1b5e20; color: white; border: none; padding: 12px 20px;
            border-radius: 8px; font-size: 15px; font-weight: 600; cursor: pointer;
            flex: 1; min-width: 120px; transition: 0.2s;
        }
        .btn:hover { background: #2e7d32; }
        .btn-pdf { background: #c62828; }
        .btn-pdf:hover { background: #b71c1c; }
        .btn-carte { background: #1565c0; }
        .btn-carte:hover { background: #0d47a1; }
        
        /* ===== RÉSULTAT ===== */
        #conseilResultat {
            margin-top: 18px; padding: 16px 18px; background: #f6f8fa;
            border-radius: 10px; border-left: 5px solid #1b5e20;
