        label { display: block; margin-top: 14px; font-weight: 600; color: #1b5e20; font-size: 13px; }
        select, input, textarea {
            width: 100%;
            padding: 9px 12px;
            margin-top: 3px;
            border: 1.5px solid #d0d7de;
            border-radius: 8px;
            font-size: 13px;
            background: #fafbfc;
            transition: border 0.2s, box-shadow 0.2s;
            font-family: inherit;
        }
        select:focus, input:focus, textarea:focus {
            border-color: #2e7d32;
            box-shadow: 0 0 0 3px rgba(46, 125, 50, 0.12);
            outline: none;
            background: #fff;
        }
        textarea { height: 70px; resize: vertical; }
        .pays-info { font-size: 11px; color: #888; text-align: right; margin-top: 2px; }
        .btn {
            background: #1b5e20;
            color: white;
            border: none;
            padding: 13px;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 18px;
            width: 100%;
            transition: background 0.2s, transform 0.1s;
        }
        .btn:hover { background: #2e7d32; }
        .btn:active { transform: scale(0.98); }
        #conseilResultat {
            margin-top: 18px;
            padding: 16px 18px;
            background: #f6f8fa;
            border-radius: 10px;
            border-left: 5px solid #1b5e20;
            display: none;
            white-space: pre-wrap;
            font-size: 13px;
            line-height: 1.7;
            font-family: 'Segoe UI', Arial, sans-serif;
            color: #1e1e1e;
            max-height: 450px;
            overflow-y: auto;
        }
