    // --- Pays à risque vectoriel (chikungunya/dengue) ---
    const paysVectoriels = ['pk','so','ke','mu','fr','it','in','bd','lk','th','mx','br','ar','co','pe','id','my','ph','vn','kh','la','mm'];

    // --- Pays à risque choléra ---
    const paysCholera = ['cd','sd','ss','td','cg','ng','gh','et','tz','zm','zw','rw','bi','ug','mw','mz','ne','ml','bf','bj','tg','ci','gn','lr','sl','cm','cf','ga','gq','ao'];

    // --- Pays à risque paludisme ---
    const paysPaludisme = ['ye','af','dj','ir','vn','kh','la','mm','cn','et','tz','zm','zw','rw','bi','ug','mw','mz','ao','cm','cf','ga','gq','ci','gn','lr','sl','bf','ml','ne','ng','bj','tg','gh','ke','so','sd','ss','cd','cg','td'];

    // ============================================================
    // LOGIQUE PRINCIPALE
    // ============================================================
    document.getElementById('obtenirConseil').addEventListener('click', function() {
        const paysSelect = document.getElementById('pays');
        const codePays = paysSelect.value;
        const paysNom = paysSelect.options[paysSelect.selectedIndex]?.text || 'Pays non reconnu';
        const age = document.getElementById('age').value || 'Non renseigné';
        const sexe = document.getElementById('sexe').value || 'Non précisé';
        const symptomesSelect = document.getElementById('symptomes');
        const symptome = symptomesSelect.value;
        const symptomeNom = symptomesSelect.options[symptomesSelect.selectedIndex]?.text || 'Non précisé';
        const description = document.getElementById('description').value || 'Aucune description';

        if (!codePays) {
            alert('Veuillez sélectionner un pays.');
            return;
        }

        // Données épidémiologiques (par défaut : risque faible)
        const dataEpi = epidemiologie[codePays] || { risque: 'faible', alerte: '✅ Situation épidémiologique stable.' };

        let conseil = '';
        conseil += '🏥 HEALTH AI – CONSEIL MÉDICAL\n';
        conseil += '═'.repeat(42) + '\n';
        conseil += '📌 Pays : ' + paysNom + '\n';
        conseil += '📅 Âge : ' + age + ' ans\n';
        conseil += '⚧️ Sexe : ' + sexe + '\n';
        conseil += '🩺 Symptôme : ' + symptomeNom + '\n';
        conseil += '📝 Description : ' + description + '\n';
        conseil += '═'.repeat(42) + '\n\n';

        // 1. ALERTE ÉPIDÉMIOLOGIQUE
        conseil += '📊 SITUATION ÉPIDÉMIOLOGIQUE (' + paysNom + ')\n';
        conseil += dataEpi.alerte + '\n\n';

        // 2. CONSEIL SPÉCIFIQUE AU SYMPTÔME
        if (symptome && conseilsSymptomes[symptome]) {
            conseil += '💡 CONSEIL SPÉCIFIQUE\n';
            conseil += conseilsSymptomes[symptome] + '\n\n';
        }

        // 3. RECOMMANDATIONS PAR RISQUE
        conseil += '📋 RECOMMANDATIONS GÉNÉRALES\n';
        if (dataEpi.risque === 'élevé') {
            conseil += '🔴 RISQUE ÉLEVÉ – Vigilance maximale.\n';
            conseil += '   • Consultez un médecin sans délai.\n';
            conseil += '   • En cas de diarrhée aqueuse, hydratez-vous et consultez.\n';
            conseil += '   • Évitez l\'automédication (paludisme, choléra).\n';
        } else if (dataEpi.risque === 'modéré') {
            conseil += '🟡 RISQUE MODÉRÉ – Restez attentif.\n';
            conseil += '   • Consultez si les symptômes persistent > 48h.\n';
            conseil += '   • En zone vectorielle, protégez-vous des piqûres.\n';
        } else {
            conseil += '🟢 RISQUE FAIBLE – Situation stable.\n';
            conseil += '   • Suivez les recommandations habituelles.\n';
            conseil += '   • Consultez si les symptômes s\'aggravent.\n';
        }

        // 4. ALERTE VECTORIELLE (chikungunya/dengue)
        if (paysVectoriels.includes(codePays)) {
            conseil += '\n🦟 ALERTE VECTORIELLE :\n';
            conseil += '   • Protégez-vous des moustiques (vêtements longs, répulsifs).\n';
            conseil += '   • Éliminez les eaux stagnantes autour de votre domicile.\n';
        }

        // 5. ALERTE CHOLÉRA
        if (paysCholera.includes(codePays)) {
            conseil += '\n💧 ALERTE CHOLÉRA :\n';
            conseil += '   • Buvez uniquement de l\'eau potable ou bouillie.\n';
            conseil += '   • Lavez-vous les mains régulièrement.\n';
            conseil += '   • En cas de diarrhée aqueuse sévère → URGENCE.\n';
        }

        // 6. ALERTE PALUDISME
        if (paysPaludisme.includes(codePays)) {
            conseil += '\n🦟 ALERTE PALUDISME :\n';
            conseil += '   • Protection anti-moustique indispensable.\n';
            conseil += '   • En cas de fièvre, consultez rapidement pour un test.\n';
        }

        conseil += '\n' + '═'.repeat(42) + '\n';
        conseil += '⚠️ Ce conseil ne remplace pas une consultation médicale.\n';
        conseil += '📞 Urgence : 15 (France) / 911 (Canada/US)';

        const resultatDiv = document.getElementById('conseilResultat');
        resultatDiv.textContent = conseil;
        resultatDiv.style.display = 'block';
        resultatDiv.className = '';
        if (dataEpi.risque === 'élevé') resultatDiv.classList.add('urgence');
        else if (dataEpi.risque === 'modéré') resultatDiv.classList.add('alerte');

        resultatDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
