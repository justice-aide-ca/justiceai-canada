        #conseilResultat.alerte { border-left-color: #f57c00; background: #fff8e1; }
        .warning {
            font-size: 11px;
            color: #777;
            margin-top: 14px;
            text-align: center;
            border-top: 1px solid #e9ecef;
            padding-top: 14px;
        }
        .warning strong { color: #c62828; }
        @media (max-width: 500px) {
            .container { padding: 16px; }
            h1 { font-size: 20px; }
            .btn { font-size: 14px; padding: 11px; }
        }
