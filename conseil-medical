        'sz': { risque: 'faible', alerte: '✅ Situation stable.' },
    };

    // --- Conseils par symptôme ---
    const conseilsSymptomes = {
        'fievre': '📌 La fièvre peut indiquer une infection (paludisme, chikungunya, infection respiratoire). Surveillez la température. Consultez si persistance > 48h.',
        'toux': '📌 La toux peut être le signe d\'une infection respiratoire. Repos, hydratation. Consultez si essoufflement ou fièvre élevée.',
        'maux_de_tete': '📌 Repos, hydratation. Si intenses ou avec raideur de la nuque, consultez rapidement.',
