            font-size: 11px;
            font-weight: bold;
            padding: 3px 14px;
            border-radius: 20px;
            margin: 0 auto 8px;
            text-align: center;
        }
        .subtitle {
            text-align: center;
            color: #666;
            font-size: 13px;
            margin: 4px 0 14px;
        }
        label {
            display: block;
            margin-top: 14px;
            font-weight: 600;
            color: #1b5e20;
            font-size: 13px;
        }
        select, input, textarea {
            width: 100%;
            padding: 9px 12px;
            margin-top: 3px;
            border: 1.5px solid #d0d7de;
            border-radius: 8px;
            font-size: 13px;
            background: #fafbfc;
            transition: border 0.2s, box-shadow 0.2s;
            font-family: inherit;
        }
        select:focus, input:focus, textarea:focus {
            border-color: #2e7d32;
            box-shadow: 0 0 0 3px rgba(46, 125, 50, 0.12);
            outline: none;
            background: #fff;
        }
        textarea {
            height: 70px;
            resize: vertical;
        }
        .pays-info {
            font-size: 11px;
            color: #888;
            text-align: right;
            margin-top: 2px;
        }
        .btn {
            background: #1b5e20;
            color: white;
            border: none;
            padding: 13px;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 18px;
            width: 100%;
            transition: background 0.2s, transform 0.1s;
        }
        .btn:hover {
            background: #2e7d32;
        }
        .btn:active {
            transform: scale(0.98);
        }
        #conseilResultat {
            margin-top: 18px;
            padding: 16px 18px;
            background: #f6f8fa;
            border-radius: 10px;
            border-left: 5px solid #1b5e20;
            display: none;
            white-space: pre-wrap;
            font-size: 13px;
            line-height: 1.7;
            font-family: 'Segoe UI', Arial, sans-serif;
            color: #1e1e1e;
            max-height: 450px;
            overflow-y: auto;
        }
        #conseilResultat.urgence {
            border-left-color: #c62828;
            background: #fff5f5;
        }
        #conseilResultat.alerte {
            border-left-color: #f57c00;
            background: #fff8e1;
        }
        .warning {
            font-size: 11px;
            color: #777;
            margin-top: 14px;
            text-align: center;
            border-top: 1px solid #e9ecef;
            padding-top: 14px;
        }
        .warning strong {
            color: #c62828;
        }
        @media (max-width: 500px) {
            .container { padding: 16px; }
            h1 { font-size: 20px; }
            .btn { font-size: 14px; padding: 11px; }
        }
    </style>
</head>
